## Helper Functions

### extractProjectName

Extract project name from Excel filename:

```javascript
function extractProjectName(excelPath) {
  const filename = path.basename(excelPath, '.xlsx');

  // Remove common prefixes
  const cleanName = filename
    .replace(/^DT_/i, '')
    .replace(/^DealTransfer_/i, '')
    .replace(/^deal_/i, '')
    .replace(/[_\s]+/g, '_');

  return cleanName || 'Project';
}
```

### mapPainPointsToModules

Map pain points and use cases to AI modules:

```javascript
function mapPainPointsToModules(painPoints, useCases) {
  // Load STANDARD_MODULES.md
  const standardModules = loadStandardModules();

  // Load logic document
  const logicDoc = loadModuleLogicDocument();

  // Map pain points → modules
  const modules = [];
  painPoints.forEach(point => {
    const module = findMatchingModule(point, standardModules, logicDoc);
    if (module) {
      modules.push(module);
    }
  });

  // Map use cases → modules
  useCases.forEach(useCase => {
    const module = findMatchingModule(useCase, standardModules, logicDoc);
    if (module && !modules.includes(module)) {
      modules.push(module);
    }
  });

  return modules;
}
```

### generateTemplateContent

Generate template content following clean content rules:

```javascript
function generateTemplateContent(extractedData, aiModules, templateStructure) {
  let content = '';

  // Fill each of 12 sections
  for (let i = 1; i <= 12; i++) {
    const section = fillSection(i, extractedData, aiModules);
    content += section + '\n\n';
  }

  return content;
}

function fillSection(sectionNumber, extractedData, aiModules) {
  switch(sectionNumber) {
    case 1:
      return generateCoverPage(extractedData);
    case 2:
      return generateProjectRequirementStatement(extractedData, aiModules);
    case 3:
      return generateScopeOfWork(extractedData);
    // ... etc for all 12 sections
  }
}
```

### generateReasoningContent

Generate complete audit trail:

```javascript
function generateReasoningContent(extractedData, aiModules, placeholders, templateStructure) {
  let content = '# Reasoning and Source Documentation\n\n';

  // For each section
  for (let i = 1; i <= 12; i++) {
    content += `## ${i}. ${getSectionTitle(i)}\n\n`;

    // Document sources
    content += `**Source**: ${extractedData.sources[i]}\n\n`;

    // Show calculations
    if (extractedData.calculations[i]) {
      content += `**Calculation**:\n${extractedData.calculations[i]}\n\n`;
    }

    // Explain placeholders
    const sectionPlaceholders = placeholders.filter(p => p.section === i);
    sectionPlaceholders.forEach(ph => {
      content += `**Placeholder ${ph.id}**: ${ph.reasoning}\n\n`;
    });
  }

  return content;
}
```

### generateChecklistContent

Generate checklist table:

```javascript
function generateChecklistContent(placeholders) {
  let content = '# Placeholder Checklist\n\n';
  content += '| ID | Section | Item | Content Estimated | Presale\'s Answer |\n';
  content += '|----|---------|------|-------------------|------------------|\n';

  placeholders.forEach(ph => {
    content += `| ${ph.id} | ${ph.section} | ${ph.item} | ${ph.estimated} | |\n`;
  });

  return content;
}
```

