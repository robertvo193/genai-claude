## Implementation

### Step 0: Validate Input

```javascript
// Parse arguments
const excelPath = args[2]; // "generate deal <excel.xlsx>"

// Validation checks
if (!excelPath) {
  return "Error: Excel file path required\nUsage: /template generate deal <excel.xlsx>";
}

// Check file exists
const fileExists = fs.existsSync(excelPath);
if (!fileExists) {
  return `Error: Excel file not found: ${excelPath}`;
}

// Check file format
if (!excelPath.endsWith('.xlsx')) {
  return "Error: Excel file must be .xlsx format (not .xls)";
}

// Check Python dependencies
const pandasInstalled = bash('python3 -c "import pandas" 2>&1').exitCode === 0;
const openpyxlInstalled = bash('python3 -c "import openpyxl" 2>&0').exitCode === 0;
if (!pandasInstalled || !openpyxlInstalled) {
  return "Error: Required Python libraries not found\nInstall: pip install pandas openpyxl";
}

// Validation passed
console.log(`✓ Excel file validated: ${excelPath}`);
console.log(`✓ Dependencies available`);
```

### Step 1: Initialize TodoWrite and State

```javascript
// Create TodoList with 5 steps
TodoWrite({
  todos: [
    {
      content: "Validate Excel File",
      status: "in_progress",
      activeForm: "Validating Excel file"
    },
    {
      content: "Extract Deal Transfer Data",
      status: "pending",
      activeForm: "Extracting Deal Transfer data"
    },
    {
      content: "Generate Template File",
      status: "pending",
      activeForm: "Generating template file"
    },
    {
      content: "Generate Reasoning File",
      status: "pending",
      activeForm: "Generating reasoning file"
    },
    {
      content: "Generate Checklist File",
      status: "pending",
      activeForm: "Generating checklist file"
    }
  ]
});

// Create state file
const sessionId = `template-${Date.now()}`;
const timestamp = bash('date +%Y%m%d_%H%M%S').trim();
const projectName = extractProjectName(excelPath); // Extract from filename
const outputDir = `./output/${projectName}_${timestamp}/`;

const state = {
  session_id: sessionId,
  status: "in_progress",
  excel_file: excelPath,
  project_name: projectName,
  output_dir: outputDir,
  steps: [
    { step: 1, name: "Validate Excel File", status: "in_progress" },
    { step: 2, name: "Extract Deal Transfer Data", status: "pending" },
    { step: 3, name: "Generate Template File", status: "pending" },
    { step: 4, name: "Generate Reasoning File", status: "pending" },
    { step: 5, name: "Generate Checklist File", status: "pending" }
  ],
  statistics: {
    s1_fields_extracted: 0,
    s2_fields_extracted: 0,
    ai_modules_mapped: 0,
    placeholders_created: 0,
    sections_filled: 0
  },
  created_at: new Date().toISOString(),
  updated_at: new Date().toISOString()
};

// Save state
bash(`mkdir -p .workflow/.template/${sessionId}`);
Write({
  file_path: `.workflow/.template/${sessionId}/state.json`,
  content: JSON.stringify(state, null, 2)
});

// Display start message
console.log(`🎯 Template Generation Started`);
console.log(`📁 Excel: ${excelPath}`);
console.log(`📊 Project: ${projectName}`);
console.log(`⏰ Timestamp: ${timestamp}`);
console.log(``);
```

### Step 2: Validate Excel File

```javascript
console.log(`[Step 1/5] Validate Excel File [🔄 IN PROGRESS]`);

// Run extraction script (validation mode)
const scriptPath = '~/.claude/skills/dealtransfer2template/scripts/extract_deal_transfer.py';
const result = bash(`python3 ${scriptPath} "${excelPath}" --validate`);

if (result.exitCode !== 0) {
  throw new Error(`Excel validation failed: ${result.stderr}`);
}

// Parse validation results
const validation = JSON.parse(result.stdout);
console.log(`✓ File exists: ${excelPath}`);
console.log(`✓ Valid Excel format (.xlsx)`);
console.log(`✓ S1 (Commercial) sheet found`);
console.log(`✓ S2 (Technical) sheet found`);

// Update state
state.steps[0].status = "completed";
state.steps[0].completed_at = new Date().toISOString();
state.steps[0].output = validation;
state.updated_at = new Date().toISOString();
Write({
  file_path: `.workflow/.template/${sessionId}/state.json`,
  content: JSON.stringify(state, null, 2)
});

// Update TodoWrite
TodoWrite({
  todos: [
    { content: "Validate Excel File", status: "completed", activeForm: "Validating Excel file" },
    { content: "Extract Deal Transfer Data", status: "in_progress", activeForm: "Extracting Deal Transfer data" },
    { content: "Generate Template File", status: "pending", activeForm: "Generating template file" },
    { content: "Generate Reasoning File", status: "pending", activeForm: "Generating reasoning file" },
    { content: "Generate Checklist File", status: "pending", activeForm: "Generating checklist file" }
  ]
});

console.log(``);
```

### Step 3: Extract Deal Transfer Data

```javascript
console.log(`[Step 2/5] Extract Deal Transfer Data [🔄 IN PROGRESS]`);

// Run extraction script
const scriptPath = '~/.claude/skills/dealtransfer2template/scripts/extract_deal_transfer.py';
const result = bash(`python3 ${scriptPath} "${excelPath}"`);

if (result.exitCode !== 0) {
  throw new Error(`Extraction failed: ${result.stderr}`);
}

// Parse extracted data
const extractedData = JSON.parse(result.stdout);

// Map pain points → AI modules
const aiModules = mapPainPointsToModules(extractedData.s2.pain_points, extractedData.s2.use_cases);

// Update statistics
state.statistics.s1_fields_extracted = extractedData.s1.field_count;
state.statistics.s2_fields_extracted = extractedData.s2.field_count;
state.statistics.ai_modules_mapped = aiModules.length;

console.log(`✓ Extracted ${extractedData.s1.field_count} fields from S1 sheet`);
console.log(`✓ Extracted ${extractedData.s2.field_count} fields from S2 sheet`);
console.log(`✓ Mapped pain points → ${aiModules.length} AI modules`);

// Count standard vs custom
const standardModules = aiModules.filter(m => m.is_standard).length;
const customModules = aiModules.filter(m => !m.is_standard).length;
console.log(`✓ Identified: ${standardModules} standard modules, ${customModules} custom modules`);

// Update state
state.steps[1].status = "completed";
state.steps[1].completed_at = new Date().toISOString();
state.steps[1].output = extractedData;
state.statistics.ai_modules_mapped = aiModules.length;
state.updated_at = new Date().toISOString();
Write({
  file_path: `.workflow/.template/${sessionId}/state.json`,
  content: JSON.stringify(state, null, 2)
});

// Update TodoWrite
TodoWrite({
  todos: [
    { content: "Validate Excel File", status: "completed", activeForm: "Validating Excel file" },
    { content: "Extract Deal Transfer Data", status: "completed", activeForm: "Extracting Deal Transfer data" },
    { content: "Generate Template File", status: "in_progress", activeForm: "Generating template file" },
    { content: "Generate Reasoning File", status: "pending", activeForm: "Generating reasoning file" },
    { content: "Generate Checklist File", status: "pending", activeForm: "Generating checklist file" }
  ]
});

console.log(``);
```

### Step 4: Generate Template File

