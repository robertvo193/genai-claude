### Step 3: Generate HTML Slides

```javascript
console.log(`[Step 2/4] Generate HTML Slides [🔄 IN PROGRESS]`);

// Read template and SLIDE_TEMPLATES.md
const templateContent = fs.readFileSync(templatePath, 'utf8');
const slideTemplatesPath = '~/.claude/skills/quotation_skill/SLIDE_TEMPLATES.md';
const slideTemplates = fs.readFileSync(slideTemplatesPath, 'utf8');

// Parse template sections (12 sections)
const sections = parseTemplateSections(templateContent);

// Read background path
const backgroundPath = 'file:///home/philiptran/.claude/skills/quotation_skill/assets/background.png';

// Generate HTML slides for each section
const htmlSlides = [];
sections.forEach((section, index) => {
  const slideNumber = String(index + 1).padStart(2, '0');
  const slideFileName = `slide${slideNumber}_${section.slug}.html`;

  // Select template based on section type
  const template = selectTemplate(section.type);

  // Generate HTML with viAct branding
  const html = generateHTML(section, template, backgroundPath);

  // Save HTML file
  fs.writeFileSync(`${outputDir}slides/${slideFileName}`, html);

  htmlSlides.push(slideFileName);
});

// Generate architecture diagram if SYSTEM ARCHITECTURE section exists
if (sections.find(s => s.title === 'SYSTEM ARCHITECTURE')) {
  // Run architecture diagram generator
  bash(`cd ~/.claude/skills/quotation_skill && python scripts/generate_architecture_diagram.py`);
  bash(`mmdc -i architecture.mmd -o architecture.png -b transparent -t dark`);
  // Embed in HTML slide
}

// Update state
state.steps[1].status = "completed";
state.steps[1].completed_at = new Date().toISOString();
state.steps[1].output = `${outputDir}slides/`;
state.updated_at = new Date().toISOString();
Write({
  file_path: `.workflow/.quotation/${sessionId}/state.json`,
  content: JSON.stringify(state, null, 2)
});

// Update TodoWrite
TodoWrite({
  todos: [
    { content: "Create Output Directory", status: "completed", activeForm: "Creating output directory" },
    { content: "Generate HTML Slides", status: "completed", activeForm: "Generating HTML slides" },
    { content: "Generate PowerPoint", status: "in_progress", activeForm: "Generating PowerPoint" },
    { content: "Generate PDF", status: "pending", activeForm: "Generating PDF" }
  ]
});

console.log(`✓ Parsed ${sections.length} sections from template`);
console.log(`✓ Generated ${htmlSlides.length} HTML slides`);
console.log(`✓ Applied viAct branding`);
console.log(`✓ Generated architecture diagram`);
console.log(``);
```

### Step 4: Generate PowerPoint

```javascript
console.log(`[Step 3/4] Generate PowerPoint [🔄 IN PROGRESS]`);

// Use pptx skill (html2pptx workflow)
const pptxOutputPath = `${outputDir}${state.project_name}_proposal.pptx`;

// Create conversion script
const convertScript = `
const html2pptx = require('/home/philiptran/.claude/skills/pptx/scripts/html2pptx.js');
const pptxgenjs = require('pptxgenjs');
const path = require('path');
const fs = require('fs');

const slidesDir = path.resolve('${outputDir}slides/');
const outputFile = path.resolve('${pptxOutputPath}');

const htmlFiles = fs.readdirSync(slidesDir)
  .filter(f => f.endsWith('.html'))
  .sort()
  .map(f => path.join(slidesDir, f));

(async () => {
  try {
    const pptx = new pptxgenjs();
    pptx.layout = 'LAYOUT_16x9';

    for (const htmlFile of htmlFiles) {
      await html2pptx(htmlFile, pptx);
    }

    await pptx.writeFile({ fileName: outputFile });
    console.log('✓ PowerPoint created!');
  } catch (error) {
    console.error('✗ Error:', error.message);
    process.exit(1);
  }
})();
`;

// Run conversion
bash(`cd ~/.claude/skills/pptx && node convert.js`);

// Validate output
if (!fs.existsSync(pptxOutputPath)) {
  throw new Error(`PowerPoint generation failed: ${pptxOutputPath} not found`);
}

// Update state
state.steps[2].status = "completed";
state.steps[2].completed_at = new Date().toISOString();
state.steps[2].output = pptxOutputPath;
state.updated_at = new Date().toISOString();
Write({
  file_path: `.workflow/.quotation/${sessionId}/state.json`,
  content: JSON.stringify(state, null, 2)
});

// Update TodoWrite
TodoWrite({
  todos: [
    { content: "Create Output Directory", status: "completed", activeForm: "Creating output directory" },
    { content: "Generate HTML Slides", status: "completed", activeForm: "Generating HTML slides" },
    { content: "Generate PowerPoint", status: "completed", activeForm: "Generating PowerPoint" },
    { content: "Generate PDF", status: "in_progress", activeForm: "Generating PDF" }
  ]
});

console.log(`✓ Converting HTML to PowerPoint...`);
console.log(`✓ Created: ${state.project_name}_proposal.pptx (${htmlSlides.length} slides)`);
console.log(``);
```

### Step 5: Generate PDF

```javascript
console.log(`[Step 4/4] Generate PDF [🔄 IN PROGRESS]`);

// Use pdf skill (PPTX → PDF conversion)
const pdfOutputPath = `${outputDir}${state.project_name}_proposal.pdf`;

// Run LibreOffice conversion
bash(`libreoffice --headless --convert-to pdf --outdir "${outputDir}" "${pptxOutputPath}"`);

// Validate output
if (!fs.existsSync(pdfOutputPath)) {
  throw new Error(`PDF generation failed: ${pdfOutputPath} not found`);
}

// Update state
state.steps[3].status = "completed";
state.steps[3].completed_at = new Date().toISOString();
state.steps[3].output = pdfOutputPath;
state.status = "completed";
state.updated_at = new Date().toISOString();
Write({
  file_path: `.workflow/.quotation/${sessionId}/state.json`,
  content: JSON.stringify(state, null, 2)
});

// Update TodoWrite
TodoWrite({
  todos: [
    { content: "Create Output Directory", status: "completed", activeForm: "Creating output directory" },
    { content: "Generate HTML Slides", status: "completed", activeForm: "Generating HTML slides" },
    { content: "Generate PowerPoint", status: "completed", activeForm: "Generating PowerPoint" },
    { content: "Generate PDF", status: "completed", activeForm: "Generating PDF" }
  ]
});

console.log(`✓ Converting PowerPoint to PDF...`);
console.log(`✓ Created: ${state.project_name}_proposal.pdf (${htmlSlides.length} pages)`);
console.log(``);
```

