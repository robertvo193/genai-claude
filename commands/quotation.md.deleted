## Implementation

### Step 0: Validate Input

**First Action**: Always validate before starting workflow

```javascript
// Parse arguments
const templatePath = args[2]; // "generate slide <template.md>"

// Validation checks
if (!templatePath) {
  return "Error: Template file path required\nUsage: /quotation generate slide <template.md>";
}

// Check file exists
const fileExists = fs.existsSync(templatePath);
if (!fileExists) {
  return `Error: Template file not found: ${templatePath}`;
}

// Check file format
if (!templatePath.endsWith('.md')) {
  return "Error: Template file must be markdown (.md) format";
}

// Check for placeholders
const templateContent = fs.readFileSync(templatePath, 'utf8');
const hasPlaceholders = /\[PLACEHOLDER_[A-Z0-9_]+\]/.test(templateContent);
if (hasPlaceholders) {
  return "Error: Template contains placeholders. Template must be verified first (no [PLACEHOLDER_ID]).";
}

// Check dependencies
const pptxSkillExists = fs.existsSync('~/.claude/skills/pptx/');
const pdfSkillExists = fs.existsSync('~/.claude/skills/pdf/');
if (!pptxSkillExists || !pdfSkillExists) {
  return "Error: Required skills not found\nPlease install: ~/.claude/skills/pptx/ and ~/.claude/skills/pdf/";
}

// Validation passed
console.log(`✓ Template validated: ${templatePath}`);
console.log(`✓ No placeholders found`);
console.log(`✓ Dependencies available`);
```

### Step 1: Initialize TodoWrite and State

```javascript
// Create TodoList with 4 steps
TodoWrite({
  todos: [
    {
      content: "Create Output Directory",
      status: "in_progress",
      activeForm: "Creating output directory"
    },
    {
      content: "Generate HTML Slides",
      status: "pending",
      activeForm: "Generating HTML slides"
    },
    {
      content: "Generate PowerPoint",
      status: "pending",
      activeForm: "Generating PowerPoint"
    },
    {
      content: "Generate PDF",
      status: "pending",
      activeForm: "Generating PDF"
    }
  ]
});

// Create state file
const sessionId = `quotation-${Date.now()}`;
const timestamp = bash('date +%Y%m%d_%H%M%S').trim();
const projectName = extractProjectName(templatePath); // Extract from template
const outputDir = `./output/${projectName}_${timestamp}/`;

const state = {
  session_id: sessionId,
  status: "in_progress",
  template: templatePath,
  project_name: projectName,
  output_dir: outputDir,
  steps: [
    { step: 1, name: "Create Output Directory", status: "in_progress" },
    { step: 2, name: "Generate HTML Slides", status: "pending" },
    { step: 3, name: "Generate PowerPoint", status: "pending" },
    { step: 4, name: "Generate PDF", status: "pending" }
  ],
  created_at: new Date().toISOString(),
  updated_at: new Date().toISOString()
};

// Save state
bash(`mkdir -p .workflow/.quotation/${sessionId}`);
Write({
  file_path: `.workflow/.quotation/${sessionId}/state.json`,
  content: JSON.stringify(state, null, 2)
});

// Display start message
console.log(`🎯 Quotation Generation Started`);
console.log(`📁 Template: ${templatePath}`);
console.log(`📊 Project: ${projectName}`);
console.log(`⏰ Timestamp: ${timestamp}`);
console.log(``);
```

