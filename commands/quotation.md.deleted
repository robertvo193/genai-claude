## Helper Functions

### extractProjectName

Extract project name from template filename or content:

```javascript
function extractProjectName(templatePath) {
  // Try filename first
  const filename = path.basename(templatePath, '.md');

  // If filename is generic, extract from template content
  if (filename === 'template' || filename === 'proposal') {
    const content = fs.readFileSync(templatePath, 'utf8');

    // Extract from "## 2. PROJECT REQUIREMENT STATEMENT"
    const match = content.match(/\*\*Project:\*\*\s*(.+)/i);
    if (match) {
      return match[1].trim().replace(/\s+/g, '_');
    }
  }

  return filename.replace(/[_\s]+/g, '_');
}
```

### parseTemplateSections

Parse 12 sections from template:

```javascript
function parseTemplateSections(templateContent) {
  const sections = [];
  const sectionRegex = /^##\s+(\d+)\.\s+(.+)$/gm;
  let match;

  while ((match = sectionRegex.exec(templateContent)) !== null) {
    sections.push({
      number: parseInt(match[1]),
      title: match[2].trim(),
      content: extractSectionContent(templateContent, match[2]),
      type: determineSectionType(match[2])
    });
  }

  return sections;
}
```

### selectTemplate

Select appropriate HTML template based on section type:

```javascript
function selectTemplate(sectionType) {
  const templateMap = {
    'cover': 'template1',
    'content': 'template2',
    'two-column': 'template3',
    'ai-module': 'template5',
    'timeline': 'template6'
  };

  return templateMap[sectionType] || 'template2';
}
```

